#!/usr/bin/env python3
"""
PDF Table Extractor - Fully Offline Tool
==========================================
Extracts tables from PDF files (text-based or scanned/image PDFs)
and exports them to Excel (.xlsx) or CSV format.

REQUIREMENTS (all pre-installed, no internet needed):
  - pymupdf        (fitz)
  - pytesseract    + tesseract-ocr system binary
  - Pillow
  - openpyxl
  - opencv-python-headless
  - pdfplumber

USAGE:
  python pdf_table_extractor.py <input.pdf> [options]

OPTIONS:
  --output PATH     Output file (default: same name as PDF with .xlsx)
  --format FORMAT   xlsx  or  csv  (default: xlsx)
  --pages RANGE     Pages to process: "all"  "1,3,5"  "2-6"  (default: all)
  --rotate MODE     Auto-rotate before OCR: auto / yes / no  (default: auto)
  --ocr MODE        OCR mode: auto / yes / no  (default: auto)
  --dpi N           Rendering DPI for scanned pages (default: 300)

EXAMPLES:
  python pdf_table_extractor.py report.pdf
  python pdf_table_extractor.py report.pdf --format csv
  python pdf_table_extractor.py report.pdf --pages 1-3 --output out.xlsx
  python pdf_table_extractor.py report.pdf --ocr yes --rotate yes --dpi 400
"""

import argparse
import sys
import os
import re
import csv
from pathlib import Path


# ---------------------------------------------------------------------------
# Dependency check
# ---------------------------------------------------------------------------
def check_deps():
    missing = []
    for pkg, pip_name in [
        ("fitz",          "pymupdf"),
        ("pytesseract",   "pytesseract"),
        ("PIL",           "Pillow"),
        ("openpyxl",      "openpyxl"),
        ("cv2",           "opencv-python-headless"),
        ("pdfplumber",    "pdfplumber"),
    ]:
        try:
            __import__(pkg)
        except ImportError:
            missing.append(pip_name)
    if missing:
        print("ERROR: Missing packages: " + ", ".join(missing))
        sys.exit(1)

check_deps()

import fitz
import pytesseract
from PIL import Image
import openpyxl
from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
import cv2
import numpy as np
import pdfplumber


# ---------------------------------------------------------------------------
# Utilities
# ---------------------------------------------------------------------------
def parse_pages(spec, total):
    if spec.lower() == "all":
        return list(range(total))
    pages = set()
    for part in spec.split(","):
        part = part.strip()
        if "-" in part:
            a, b = part.split("-", 1)
            pages.update(range(int(a) - 1, int(b)))
        else:
            pages.add(int(part) - 1)
    return sorted(p for p in pages if 0 <= p < total)


def page_has_text(fitz_page, threshold=50):
    return len(fitz_page.get_text("text").strip()) > threshold


def render_page(fitz_page, dpi=300):
    mat = fitz.Matrix(dpi / 72, dpi / 72)
    pix = fitz_page.get_pixmap(matrix=mat, colorspace=fitz.csRGB)
    return Image.frombytes("RGB", [pix.width, pix.height], pix.samples)


def auto_rotate(pil_img):
    try:
        osd = pytesseract.image_to_osd(pil_img, output_type=pytesseract.Output.DICT)
        angle = osd.get("rotate", 0)
        if angle:
            pil_img = pil_img.rotate(-angle, expand=True)
            print(f"      Auto-rotated {angle} deg.")
    except Exception:
        pass
    return pil_img


# ---------------------------------------------------------------------------
# OCR-based table reconstruction
# Aligns OCR words into a 2-D grid using x/y clustering.
# ---------------------------------------------------------------------------
def ocr_to_grid(pil_img):
    data = pytesseract.image_to_data(
        pil_img,
        output_type=pytesseract.Output.DICT,
        config="--psm 6",
    )

    words = [
        {
            "text": str(data["text"][i]).strip(),
            "left": data["left"][i],
            "top":  data["top"][i],
        }
        for i in range(len(data["text"]))
        if int(data["conf"][i]) > 10 and str(data["text"][i]).strip()
    ]

    if not words:
        return []

    def cluster(values, gap):
        sv = sorted(set(values))
        clusters, cur = [], [sv[0]]
        for v in sv[1:]:
            if v - cur[-1] <= gap:
                cur.append(v)
            else:
                clusters.append(cur)
                cur = [v]
        clusters.append(cur)
        mapping = {}
        for idx, cl in enumerate(clusters):
            for v in cl:
                mapping[v] = idx
        return mapping

    row_map = cluster([w["top"]  for w in words], gap=12)
    col_map = cluster([w["left"] for w in words], gap=20)

    for w in words:
        w["r"] = row_map[w["top"]]
        w["c"] = col_map[w["left"]]

    n_rows = max(w["r"] for w in words) + 1
    n_cols = max(w["c"] for w in words) + 1
    grid = [[""] * n_cols for _ in range(n_rows)]

    for w in words:
        r, c = w["r"], w["c"]
        grid[r][c] = (grid[r][c] + " " + w["text"]).strip()

    return [row for row in grid if any(c.strip() for c in row)]


# ---------------------------------------------------------------------------
# Text-based table extraction with pdfplumber
# ---------------------------------------------------------------------------
def text_to_grid(pdf_path, page_num):
    try:
        with pdfplumber.open(pdf_path) as pdf:
            pg = pdf.pages[page_num]
            tables = pg.extract_tables()
            if tables:
                best = max(tables, key=lambda t: sum(len(r) for r in t))
                return [[cell or "" for cell in row] for row in best]
            text = pg.extract_text()
            if text:
                return [line.split() for line in text.splitlines() if line.strip()]
    except Exception as exc:
        print(f"      pdfplumber error: {exc}")
    return []


# ---------------------------------------------------------------------------
# Excel output
# ---------------------------------------------------------------------------
def write_excel(all_grids, out_path):
    wb = openpyxl.Workbook()
    wb.remove(wb.active)

    hdr_fill = PatternFill("solid", fgColor="4472C4")
    hdr_font = Font(bold=True, color="FFFFFF", name="Calibri", size=10)
    dat_font = Font(name="Calibri", size=10)
    c_align  = Alignment(horizontal="center", vertical="center", wrap_text=True)
    l_align  = Alignment(horizontal="left",   vertical="center", wrap_text=True)
    thin = Side(border_style="thin", color="BFBFBF")
    brd  = Border(left=thin, right=thin, top=thin, bottom=thin)

    for sheet_name, grid in all_grids:
        ws = wb.create_sheet(title=sheet_name[:31])
        if not grid:
            ws["A1"] = "No table data found on this page."
            continue
        for ri, row in enumerate(grid, 1):
            for ci, val in enumerate(row, 1):
                cell = ws.cell(row=ri, column=ci, value=str(val).strip() if val else "")
                cell.border = brd
                if ri == 1:
                    cell.fill, cell.font, cell.alignment = hdr_fill, hdr_font, c_align
                else:
                    cell.font, cell.alignment = dat_font, l_align
        for col_cells in ws.columns:
            ltr = col_cells[0].column_letter
            w = max((len(str(c.value)) for c in col_cells if c.value), default=8)
            ws.column_dimensions[ltr].width = min(max(w + 2, 8), 45)
        ws.freeze_panes = "A2"

    wb.save(out_path)
    print(f"  -> Saved: {out_path}")


# ---------------------------------------------------------------------------
# CSV output (one file per page/sheet)
# ---------------------------------------------------------------------------
def write_csv(all_grids, out_path):
    base   = Path(out_path).stem
    parent = Path(out_path).parent
    for sheet_name, grid in all_grids:
        safe = re.sub(r"[^\w\-]", "_", sheet_name)
        fp = parent / f"{base}_{safe}.csv"
        with open(fp, "w", newline="", encoding="utf-8-sig") as f:
            csv.writer(f).writerows(
                [str(c).strip() if c else "" for c in row] for row in grid
            )
        print(f"  -> Saved: {fp}")


# ---------------------------------------------------------------------------
# Main pipeline
# ---------------------------------------------------------------------------
def run(args):
    pdf_path = Path(args.input)
    if not pdf_path.exists():
        print(f"ERROR: File not found: {pdf_path}")
        sys.exit(1)

    out_path = Path(args.output) if args.output else \
               pdf_path.with_suffix(".xlsx" if args.format == "xlsx" else ".csv")

    print("\n" + "=" * 50)
    print("  PDF Table Extractor (Offline)")
    print("=" * 50)
    print(f"  Input : {pdf_path}")
    print(f"  Output: {out_path}")
    print(f"  Format: {args.format.upper()}")

    doc = fitz.open(str(pdf_path))
    total = len(doc)
    pages = parse_pages(args.pages, total)
    print(f"  Pages : {[p+1 for p in pages]} (of {total})\n")

    all_grids = []

    for p in pages:
        label = f"Page_{p + 1}"
        print(f"  [{label}]")
        fitz_page = doc[p]

        use_ocr = (args.ocr == "yes") or (args.ocr == "auto" and not page_has_text(fitz_page))

        if use_ocr:
            print("    Mode : OCR")
            img = render_page(fitz_page, dpi=args.dpi)
            if args.rotate in ("yes", "auto"):
                img = auto_rotate(img)
            grid = ocr_to_grid(img)
        else:
            print("    Mode : Text")
            grid = text_to_grid(str(pdf_path), p)

        rows = len(grid)
        cols = max((len(r) for r in grid), default=0)
        print(f"    Result: {rows} rows x {cols} cols")
        all_grids.append((label, grid))

    doc.close()

    if args.format == "xlsx":
        write_excel(all_grids, str(out_path))
    else:
        write_csv(all_grids, str(out_path))

    print("\nExtraction complete.")


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------
if __name__ == "__main__":
    p = argparse.ArgumentParser(
        description="Extract tables from PDF to Excel/CSV (fully offline).",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    p.add_argument("input",           help="Input PDF path")
    p.add_argument("--output",        help="Output file path",               default=None)
    p.add_argument("--format",        help="xlsx or csv",                    default="xlsx",
                   choices=["xlsx", "csv"])
    p.add_argument("--pages",         help='Page range: all / 1,3 / 2-5',   default="all")
    p.add_argument("--rotate",        help="Rotation: auto / yes / no",      default="auto",
                   choices=["auto", "yes", "no"])
    p.add_argument("--ocr",           help="OCR mode: auto / yes / no",      default="auto",
                   choices=["auto", "yes", "no"])
    p.add_argument("--dpi",           help="Render DPI (default 300)",       default=300, type=int)
    run(p.parse_args())
