def check_model_available(model_name: str) -> bool:
    """Check whether the model is already pulled in Ollama.
    Compatible with new Ollama SDK where models are objects not dicts.
    """
    try:
        response   = ollama.list()
        model_list = response.models        # your SDK: always an object

        for m in model_list:
            # object attribute access — confirmed working on your system
            name = getattr(m, "name", "") or getattr(m, "model", "")
            print(f"  Checking: {name}")
            if model_name.lower() in str(name).lower():
                return True
        return False

    except Exception as e:
        print(f"  [!] Could not check models: {e}")
        return False
